{
  "compilerOptions": {
    "module": "ESNext",
    "types": ["bun-types"],
    "forceConsistentCasingInFileNames": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@prisma-local/*": ["./generated/*"],
      "@src/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts"]
}
